# TrendRadar 환경 변수 설정 예시
# 이 파일을 .env로 복사하고 실제 값을 입력하세요.
# cp .env.example .env

# ====================================
# Naver DataLab (필수)
# ====================================
# 네이버 개발자센터에서 발급: https://developers.naver.com
NAVER_CLIENT_ID=your_naver_client_id_here
NAVER_CLIENT_SECRET=your_naver_client_secret_here

# ====================================
# YouTube Data API v3 (선택)
# ====================================
# Google Cloud Console에서 발급: https://console.cloud.google.com
# YouTube API 활성화 필요
YOUTUBE_API_KEY=your_youtube_api_key_here

# ====================================
# Reddit API (선택)
# ====================================
# Reddit App Settings에서 발급: https://www.reddit.com/prefs/apps
# Script type 애플리케이션으로 생성
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
# REDDIT_USER_AGENT=TrendRadar/1.0 (optional)

# ====================================
# 데이터베이스 설정 (선택)
# ====================================
# DuckDB 파일 경로 (기본값: data/trendradar.duckdb)
# DB_PATH=data/trendradar.duckdb

# ====================================
# 리포트 설정 (선택)
# ====================================
# 리포트 출력 디렉토리 (기본값: docs/reports)
# REPORT_DIR=docs/reports

# ====================================
# 로깅 설정 (선택)
# ====================================
# 로그 레벨: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO
# LOG_FILE=logs/trendradar.log

# ====================================
# 알림 설정 (선택)
# ====================================
# Slack 웹훅 URL (에러 알림용)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# 이메일 알림 설정 (SMTP)
# EMAIL_ENABLED=false
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_SENDER=your-email@gmail.com
# EMAIL_PASSWORD=your-app-password
# EMAIL_RECEIVER=recipient@example.com

# ====================================
# 고급 설정 (선택)
# ====================================
# 수집 간격 (시간 단위)
# COLLECTION_INTERVAL=24

# Rate Limit 설정
# REQUESTS_PER_MINUTE=60

# 타임아웃 (초)
# REQUEST_TIMEOUT=30

# 재시도 횟수
# MAX_RETRIES=3
